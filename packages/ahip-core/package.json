{
  "name": "@ahip/core",
  "version": "0.2.0-preview",
  "description": "Core validation, schema, and safety helpers for the Agent-Human Interaction Protocol.",
  "license": "Apache-2.0",
  "private": false,
  "keywords": [
    "ahip",
    "agent",
    "protocol",
    "validation",
    "json-schema"
  ],
  "homepage": "https://github.com/ArcheLabs/ahip#readme",
  "bugs": {
    "url": "https://github.com/ArcheLabs/ahip/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ArcheLabs/ahip.git",
    "directory": "packages/ahip-core"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./schema/ahip-v0.2.schema.json": "./src/schema/ahip-v0.2.schema.json"
  },
  "files": [
    "dist",
    "src/schema/ahip-v0.2.schema.json",
    "LICENSE",
    "README.md",
    "README.zh-CN.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "lint": "eslint src test --ext .ts"
  }
}

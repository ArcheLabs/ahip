        "clipboard": {
          "type": "boolean"
        },
        "wallet": {
          "type": "boolean"
        },
        "storage": {
          "enum": [
            "none",
            "session"
          ]
        },
        "extensions": {
          "$ref": "#/$defs/ExtensionsMap"
        }
      }
    },

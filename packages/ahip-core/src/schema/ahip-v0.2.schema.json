      "properties": {
        "protocol_version": {
          "type": "string"
        },
        "supported_item_kinds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "supported_blocks": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "supported_actions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "supported_widget_types": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "supported_artifact_kinds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "limits": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "max_blocks_per_item": {
              "type": "number",
              "minimum": 0
            },
            "max_inline_table_rows": {
              "type": "number",
              "minimum": 0
            },
            "max_chart_points": {
              "type": "number",
              "minimum": 0
            }
          }
        },
        "extensions": {
          "$ref": "#/$defs/ExtensionsMap"
        }
      }
    }
  }
}

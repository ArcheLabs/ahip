      "type": "object",
      "additionalProperties": false,
      "required": [
        "patch_id",
        "target",
        "op",
        "path"
      ],
      "properties": {
        "patch_id": {
          "type": "string"
        },
        "target": {
          "type": "string"
        },
        "op": {
          "enum": [
            "set",
            "merge",
            "append",
            "remove"
          ]
        },
        "path": {
          "type": "string"
        },
        "value": true,
        "extensions": {
          "$ref": "#/$defs/ExtensionsMap"
        }
      }
    },
    "ExtensionIdentifier": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:[.-][a-z0-9]+)*(?:\\.[a-z0-9]+(?:[.-][a-z0-9]+)*)*/[a-z0-9][a-z0-9._-]*$",
      "description": "Namespaced extension identifier of the form <namespace>/<name>."
    },
    "ExtensionsMap": {
      "type": "object",
      "propertyNames": {
        "pattern": "^[a-z0-9]+(?:[.-][a-z0-9]+)*(?:\\.[a-z0-9]+(?:[.-][a-z0-9]+)*)*/[a-z0-9][a-z0-9._-]*$"
      },
      "additionalProperties": true,
      "description": "Map keyed by extension identifiers."
    },
    "CoreBlockType": {
      "type": "string",
      "enum": [
        "text",
        "markdown",
        "image",
        "file",
        "code",
        "quote",
        "divider",
        "badge",
        "stat",
        "table",
        "chart",
        "entity_card",
        "form",
        "status",
        "error",
        "payment_request",
        "payment_receipt"
      ]
    },

        "id": {
          "type": "string"
        },
        "widget_id": {
          "type": "string"
        },
        "widget_type": {
          "type": "string",
          "minLength": 1
        },
        "props": {
          "type": "object",
          "additionalProperties": true
        },
        "permissions": {
          "$ref": "#/$defs/WidgetPermissions"
        },
        "fallback_text": {
          "type": "string"
        },
        "extensions": {
          "$ref": "#/$defs/ExtensionsMap"
        }
      }

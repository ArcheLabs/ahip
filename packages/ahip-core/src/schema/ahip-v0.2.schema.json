      "type": "object",
      "additionalProperties": false,
      "required": [
        "intent_id",
        "tool_name",
        "status"
      ],
      "properties": {
        "intent_id": {
          "type": "string"
        },
        "tool_name": {
          "type": "string"
        },
        "status": {
          "enum": [
            "proposed",
            "awaiting_approval",
            "awaiting_user_input",
            "ready",
            "running",
            "completed",
            "failed"
          ]
        },
        "title": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "proposed_args": {
          "$ref": "#/$defs/arbitraryObject"
        },
        "missing_fields": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "result_artifact_id": {
          "type": "string"
        },
        "fallback_text": {
          "type": "string"
        },
        "extensions": {
          "$ref": "#/$defs/ExtensionsMap"
        }
      }
    },

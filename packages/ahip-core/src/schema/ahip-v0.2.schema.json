      "oneOf": [
        {
          "enum": [
            "dataset",
            "document",
            "report",
            "deck_outline",
            "slide_spec",
            "code_bundle",
            "payment_intent",
            "task_snapshot",
            "image",
            "audio",
            "video",
            "custom"
          ]
        },
        {
          "$ref": "#/$defs/ExtensionIdentifier"
        }
      ]
    },

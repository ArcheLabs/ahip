          "type": "string",
          "format": "uri"
        },
        "mime_type": {
          "type": "string"
        },
        "checksum": {
          "type": "string"
        },
        "summary": {
          "type": "string"
        },
        "extensions": {
          "$ref": "#/$defs/ExtensionsMap"
        },
        "fallback_text": {
          "type": "string"
        }
      }
    },

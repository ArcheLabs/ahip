        "style": {
          "enum": [
            "primary",
            "secondary",
            "danger"
          ]
        },
        "disabled": {
          "type": "boolean"
        },
        "payload": {
          "$ref": "#/$defs/arbitraryObject"
        },
        "fallback_text": {
          "type": "string"
        },
        "extensions": {
          "$ref": "#/$defs/ExtensionsMap"
        }

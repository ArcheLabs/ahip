        "expires_at": {
          "type": "string",
          "format": "date-time"
        },
        "payload": {
          "$ref": "#/$defs/arbitraryObject"
        },
        "fallback_text": {
          "type": "string"
        },
        "extensions": {
          "$ref": "#/$defs/ExtensionsMap"
        }
      }
    },
    "ApprovalResponse": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "approval_id",

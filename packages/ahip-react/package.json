{
  "name": "@ahip/react",
  "version": "0.2.0-preview.0",
  "description": "Host-controlled React renderer for the Agent-Human Interaction Protocol.",
  "license": "Apache-2.0",
  "private": false,
  "keywords": [
    "ahip",
    "agent",
    "protocol",
    "react",
    "renderer"
  ],
  "homepage": "https://github.com/ArcheLabs/ahip#readme",
  "bugs": {
    "url": "https://github.com/ArcheLabs/ahip/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ArcheLabs/ahip.git",
    "directory": "packages/ahip-react"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md",
    "README.zh-CN.md"
  ],
  "scripts": {
    "build": "tsup src/index.tsx --format esm,cjs --dts --external react --external react-dom",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "lint": "eslint src --ext .ts,.tsx"
  },
  "dependencies": {
    "@ahip/core": "workspace:*"
  },
  "peerDependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  }
}

{
  "name": "@ahip/examples",
  "version": "0.2.0-preview.0",
  "description": "Examples, fixtures, and showcase data for the Agent-Human Interaction Protocol.",
  "license": "Apache-2.0",
  "private": false,
  "keywords": [
    "ahip",
    "agent",
    "protocol",
    "fixtures",
    "examples"
  ],
  "homepage": "https://github.com/ArcheLabs/ahip#readme",
  "bugs": {
    "url": "https://github.com/ArcheLabs/ahip/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ArcheLabs/ahip.git",
    "directory": "packages/ahip-examples"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md",
    "README.zh-CN.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "lint": "eslint src --ext .ts,.tsx"
  },
  "dependencies": {
    "@ahip/core": "workspace:*",
    "@ahip/react": "workspace:*"
  }
}

{
  "name": "@ahip/examples",
  "version": "0.2.0-preview.0",
  "description": "Examples, fixtures, and showcase data for the Agent-Human Interaction Protocol.",
  "license": "Apache-2.0",
  "private": false,
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "lint": "eslint src --ext .ts,.tsx"
  },
  "dependencies": {
    "@ahip/core": "workspace:*",
    "@ahip/react": "workspace:*"
  }
}
